<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:SmartAgri.ViewModels"
             x:Class="SmartAgri.Views.LoginPage"
             x:DataType="viewmodels:LoginViewModel"
             Title="登录">
    <VerticalStackLayout Padding="24" Spacing="12">
        <Entry Placeholder="用户名" Text="{Binding Username}" />
        <Entry Placeholder="密码" IsPassword="True" Text="{Binding Password}" />
        <Button Text="登录" Command="{Binding LoginCommand}"/>
        <Label TextColor="Red" Text="{Binding Message}" />
    </VerticalStackLayout>
</ContentPage>